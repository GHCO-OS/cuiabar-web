{
  "name": "cuiabar-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck:app": "tsc --noEmit",
    "typecheck:worker": "tsc -p tsconfig.worker.json --noEmit",
    "build": "tsc -b && vite build && npm run build:ssr && node scripts/generate-seo-assets.mjs",
    "build:ci": "npm run build && npm run build:worker",
    "build:ssr": "vite build --ssr src/ssr/render.tsx --outDir .ssr --emptyOutDir",
    "build:worker": "tsc -p tsconfig.worker.json",
    "preview": "vite preview",
    "lint": "npm run typecheck:app && npm run typecheck:worker",
    "test": "npm run typecheck:worker && npx tsx --test tests/**/*.test.ts",
    "perf:check": "node scripts/check-performance-budgets.mjs",
    "deploy:pages": "npm run build && wrangler pages deploy dist --project-name=cuiabar-site",
    "deploy:worker": "npm run build:ci && wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply cuiabar_crm --local",
    "d1:migrate:remote": "wrangler d1 migrations apply cuiabar_crm --remote",
    "baileys:node20": "powershell -ExecutionPolicy Bypass -File scripts/install-node20-runtime.ps1",
    "baileys:prepare": "powershell -ExecutionPolicy Bypass -File scripts/run-baileys-runtime.ps1 -Mode prepare",
    "baileys:dev": "powershell -ExecutionPolicy Bypass -File scripts/run-baileys-runtime.ps1 -Mode dev",
    "baileys:build": "powershell -ExecutionPolicy Bypass -File scripts/run-baileys-runtime.ps1 -Mode build",
    "baileys:check": "powershell -ExecutionPolicy Bypass -File scripts/run-baileys-runtime.ps1 -Mode check",
    "baileys:autostart:install": "powershell -ExecutionPolicy Bypass -File scripts/install-baileys-autostart.ps1",
    "baileys:autostart:status": "powershell -ExecutionPolicy Bypass -File scripts/baileys-autostart-status.ps1"
  },
  "dependencies": {
    "hono": "^4.12.7",
    "jose": "^6.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wrangler": "^4.71.0"
  }
}
